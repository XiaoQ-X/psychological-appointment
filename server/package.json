{
  "name": "@anxin/server",
  "version": "1.0.0",
  "private": true,
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "db:migrate": "dotenv -e ../.env -- prisma migrate dev --name init --schema ../database/schema.prisma",
    "db:migrate:deploy": "dotenv -e ../.env -- prisma migrate deploy --schema ../database/schema.prisma",
    "db:push": "dotenv -e ../.env -- prisma db push --schema ../database/schema.prisma",
    "db:seed": "dotenv -e ../.env -- node ../database/seed.js",
    "db:studio": "dotenv -e ../.env -- prisma studio --schema ../database/schema.prisma",
    "test:api": "node src/test-api.js"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "prisma": "^6.19.0"
  }
}
